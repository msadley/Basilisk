{
  "name": "basilisk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx tsc -b",
    "dev": "concurrently \"npm:dev:*\"",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:relay": "npm run dev --prefix apps/relay",
    "dev:test": "npm run dev --prefix apps/test",
    "vite": "npm run dev --prefix apps/web",
    "relay": "npm run build && node apps/relay/dist/index.js"
  },
  "author": "Adley Silva Mendes",
  "license": "ISC",
  "description": "A chat app built on top of libp2p, using TypeScript.",
  "overrides": {
    "@multiformats/multiaddr": "^13.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
