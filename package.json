{
  "name": "basilisk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx tsc -b",
    "vite": "npm run dev --prefix apps/web",
    "relay": "npm run build && node apps/relay/dist/index.js"
  },
  "author": "Adley Silva Mendes",
  "license": "ISC",
  "description": "A chat app built on top of libp2p, using TypeScript.",
  "devDependencies": {
    "@types/events": "^3.0.3",
    "@types/node": "^24.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "cross-env": "^10.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.9.4",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "arktype": "^2.2.1",
    "comlink": "^4.4.2"
  },
  "overrides": {
    "esbuild": "^0.25.12"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "es5-ext@0.10.64": true,
    "fsevents@2.3.3": true,
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true
  }
}
